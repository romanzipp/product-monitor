# Required
PUSHOVER_TOKEN=your-pushover-application-token
PUSHOVER_USER=your-pushover-user-or-group-key

# Optional: notification tuning
PUSHOVER_PRIORITY=0
PUSHOVER_DEVICE=

# Optional: runtime behavior
CHECK_INTERVAL=5m
HTTP_TIMEOUT=30s
DB_PATH=klima.db
DEBUG=false
# Ignore offers priced above this (whole euros). 0 = no limit.
PRICE_MAX=0

# BraucheKlima source (aggregated feed)
BRAUCHEKLIMA_ENABLED=true
BRAUCHEKLIMA_URL=https://braucheklima.de/api/availability
BRAUCHEKLIMA_PRODUCT=Midea Portasplit

# FlareSolverr proxy for Cloudflare-protected sources (braucheklima). Leave empty
# to fetch directly (requires a residential IP). Set to a FlareSolverr base URL
# to bypass Cloudflare from datacenter IPs.
FLARESOLVERR_URL=
FLARESOLVERR_TIMEOUT=60s

# OBI source (direct product availability API)
OBI_ENABLED=true
OBI_PRODUCT_ID=8620890

# MediaMarkt source (product-page availability check; needs FlareSolverr).
# Override the URL if monitoring a different PortaSplit variant.
MEDIAMARKT_ENABLED=true
MEDIAMARKT_URL=https://www.mediamarkt.de/de/product/_midea-porta-split-klimaanlage-grau-max-raumgrosse-42-m-eek-a-142245268.html

# Euronics source (product-page availability check; needs FlareSolverr).
EURONICS_ENABLED=true
EURONICS_URL=https://www.euronics.de/haus-und-haushalt/heizen-lueften-kuehlen/kuehlen/split-klimageraete/porta-split-split-klimageraet-a-4065327878899

# Globus Baumarkt source (product-page availability check; needs FlareSolverr).
GLOBUS_ENABLED=true
GLOBUS_URL=https://www.globus-baumarkt.de/p/midea-portasplit-mobile-split-klimaanlage-12000-btu-heiz-kuehlfunktion-0694600235/

# Home postal code: the single location reference. OBI queries against it, and
# the in-store filter prefix defaults to its region (first two digits).
LOCAL_PLZ=36037

# Local in-store filter: keep in-store availability only for stores whose PLZ
# starts with one of these comma-separated prefixes. Defaults to the LOCAL_PLZ
# region ("36"). Empty disables the filter. Online availability is never filtered.
LOCAL_PLZ_PREFIXES=36
